# 跨平台开发：统一换行符配置

# 自动检测文本文件并转换换行符
* text=auto

# Python 文件使用 LF
*.py text eol=lf

# Shell 脚本使用 LF
*.sh text eol=lf

# Docker 相关文件使用 LF
Dockerfile text eol=lf
.dockerignore text eol=lf

# YAML 配置文件使用 LF
*.yml text eol=lf
*.yaml text eol=lf

# Markdown 文档使用 LF
*.md text eol=lf

# JSON 配置文件使用 LF
*.json text eol=lf

# TOML 配置文件使用 LF
*.toml text eol=lf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
